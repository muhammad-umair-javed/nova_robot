<?xml version="1.0" ?>
<robot name="nova_robot" xmlns:xacro="http://ros.org/wiki/xacro">


  <!-- Init colour -->
  <material name="black">
      <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <material name="dark">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>

  <material name="light_black">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>

  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>

  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="orange">
    <color rgba="1.0 0.4235 0.0392 1.0"/>
  </material>

  <material name="brown">
    <color rgba="0.8706 0.8118 0.7647 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>

  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <!-- ==================== BASE ==================== -->

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- z=0.044 so caster diameter (0.044) bridges base bottom to ground -->
    <origin xyz="0 0 0.044" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${0.15/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.25" length="0.15"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${0.15/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.25" length="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="8.0"/>
      <!-- m=8, r=0.25, l=0.15: ixx=iyy=m(3r²+l²)/12, izz=mr²/2 -->
      <inertia ixx="0.14" ixy="0.0" ixz="0.0"
              iyy="0.14" iyz="0.0"
              izz="0.25"/>
    </inertial>
  </link>

  <!-- ==================== WHEELS ==================== -->

  <!--
    base_link origin at z=0.044 from ground.
    Wheel radius = 0.075 → wheel center must be at z=0.075 from ground.
    Joint Z = 0.075 - 0.044 = 0.031
  -->
  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0.0 ${0.25 + 0.026} 0.031" rpy="${-pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.050" radius="0.075"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.050" radius="0.075"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <!-- m=0.5, r=0.075, l=0.05: ixx=izz=m(3r²+l²)/12, iyy=mr²/2 -->
      <inertia ixx="0.000807" ixy="0" ixz="0"
              iyy="0.001406" iyz="0"
              izz="0.000807"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0.0 -${0.25 + 0.026} 0.031" rpy="${-pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.050" radius="0.075"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.050" radius="0.075"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000807" ixy="0" ixz="0"
              iyy="0.001406" iyz="0"
              izz="0.000807"/>
    </inertial>
  </link>

  <!-- ==================== CASTERS ==================== -->

  <!--
    Caster radius = 0.022m → diameter = 0.044m = base_joint Z.
    Joint Z = -0.022 → caster center at world z=0.022 ✅
    Caster top  = z=0.000 in base_link frame → flush with base bottom ✅
    Caster bottom = world z=0.000 → touches ground ✅
  -->
  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_front_link"/>
    <origin xyz="0.20 0.0 -0.022" rpy="0 0 0"/>
  </joint>

  <link name="caster_front_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.022"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.022"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.1"/>
      <!-- sphere: I = 2mr²/5 = 2*0.1*0.022²/5 = 0.0000194 -->
      <inertia ixx="0.0000194" ixy="0.0" ixz="0.0"
              iyy="0.0000194" iyz="0.0"
              izz="0.0000194"/>
    </inertial>
  </link>

  <joint name="caster_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_link"/>
    <origin xyz="-0.20 0.0 -0.022" rpy="0 0 0"/>
  </joint>

  <link name="caster_back_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.022"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.022"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0000194" ixy="0.0" ixz="0.0"
              iyy="0.0000194" iyz="0.0"
              izz="0.0000194"/>
    </inertial>
  </link>



  <!-- ==================== IMU ==================== -->

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- imu_link is intentionally massless/visualless — it's a sensor frame only -->
  <link name="imu_link"/>


  <!-- ==================== LIDAR ==================== -->

  <joint name="scan_joint" type="fixed">
  <parent link="base_link"/>
  <child link="base_scan"/>
  <origin xyz="0.15 0 0.17" rpy="0 0 0"/>
  </joint>

  <link name="base_scan">

    <visual>
      <origin xyz="0 0 ${0.036/2 - 0.02}" rpy="0 0 0"/>
      <geometry>
        <!-- LDS-01: Ø95mm diameter, 36mm height -->
        <cylinder length="0.036" radius="0.0475"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0 0 ${0.036/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.036" radius="0.0475"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.114"/>
      <origin xyz="0 0 0"/>
      <!-- Solid cylinder: ixx=iyy = m(3r²+h²)/12, izz = mr²/2 -->
      <inertia ixx="0.0000842" ixy="0.0" ixz="0.0"
              iyy="0.0000842" iyz="0.0"
              izz="0.0001287"/>
    </inertial>

  </link>

  <!-- ==================== Central Column ==================== -->


  <joint name="central_column" type="fixed">
    <parent link="base_link"/>
    <child link="central_column" />
    <origin xyz="0 0 ${0.15}" rpy="0 0 0"/>
  </joint>

  <link name="central_column">

    <visual>
      <origin xyz="0 0 ${0.7 / 2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius = '0.075' length = '0.7'/>
      </geometry>
      <material name="white"/>
    </visual>

    <collision>
      <origin xyz="0 0 ${0.7 / 2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius = '0.075' length = '0.7'/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.084479" ixy="0.0" ixz="0.0"
               iyy="0.084479" iyz="0.0"
               izz="0.005625" />
    </inertial>
  </link>


  <!-- ==================== Upper Body ==================== -->


  <joint name="upper_body" type="fixed">
    <parent link="central_column"/>
    <child link="upper_body" />
    <origin xyz="0 0 ${0.7}" rpy="0 0 0"/>
  </joint>

  <link name="upper_body">

    <visual>
      <origin xyz="0 0 ${0.29 / 2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius = '0.18' length = '0.29'/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 ${0.29 / 2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius = '0.18' length = '0.29'/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="3.0"/>
      <inertia ixx="0.045330" ixy="0.0" ixz="0.0"
               iyy="0.045330" iyz="0.0"
               izz="0.0486" />
    </inertial>
  </link>

  <!-- ==================== CAMERA ==================== -->

  <joint name="camera_joint" type="fixed">
  <origin xyz="0.08 0 0.29" rpy="0 0 0"/>
  <parent link="upper_body"/>
  <child link="camera_link"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- D435: 90mm wide, 25mm tall, 25mm deep (x=depth, y=width, z=height) -->
        <box size="0.025 0.090 0.025"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.090 0.025"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.072"/>  <!-- D435 actual mass: 72g -->
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000010" ixy="0.0" ixz="0.0"
              iyy="0.000004" iyz="0.0"
              izz="0.000012"/>
    </inertial>
  </link>

  <!-- RGB sensor: -17.44mm from camera_link center along Y -->
  <joint name="camera_rgb_joint" type="fixed">
    <origin xyz="0.000 -0.01744 0.000" rpy="0 0 0"/>
    <parent link="camera_link"/>
    <child link="camera_rgb_frame"/>
  </joint>
  <link name="camera_rgb_frame"/>

  <joint name="camera_rgb_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
    <parent link="camera_rgb_frame"/>
    <child link="camera_rgb_optical_frame"/>
  </joint>
  <link name="camera_rgb_optical_frame"/>

  <!-- Depth reference (left IR): +14.74mm from camera_link center along Y -->
  <joint name="camera_depth_joint" type="fixed">
    <origin xyz="0.000 0.01474 0.000" rpy="0 0 0"/>
    <parent link="camera_link"/>
    <child link="camera_depth_frame"/>
  </joint>
  <link name="camera_depth_frame"/>

  <joint name="camera_depth_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
    <parent link="camera_depth_frame"/>
    <child link="camera_depth_optical_frame"/>
  </joint>
  <link name="camera_depth_optical_frame"/>
  


</robot>