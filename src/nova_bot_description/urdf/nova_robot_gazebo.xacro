<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ========== DIFFERENTIAL DRIVE ========== -->
  <gazebo>
    <plugin name="nova_robot_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>30</update_rate>

      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>

      <!-- 
        wheel Y offset from base_link = 0.25 (base radius) + 0.026 (clearance) = 0.276m
        separation = 0.276 × 2 = 0.552m
      -->
      <wheel_separation>0.552</wheel_separation>

      <!--
        wheel radius = 0.075m → diameter = 0.075 × 2 = 0.150m
      -->
      <wheel_diameter>0.150</wheel_diameter>

      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- ========== IMU ========== -->
  <gazebo reference="imu_link">
    <sensor name="nova_robot_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>

      <!-- ADD THIS BLOCK -->
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0014</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0014</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0014</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0096</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0096</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0096</stddev></noise></z>
        </linear_acceleration>
      </imu>

      <plugin name="nova_robot_imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=imu</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

  
  <!-- ========== LIDAR ========== -->
  <gazebo reference="base_scan">
    <sensor name="nova_robot_lidar" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>5</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>3.5</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="nova_robot_lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <!-- raw unfiltered scan — filter node will publish /scan -->
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>base_scan</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ========== RGB CAMERA ========== -->
  <gazebo reference="camera_link">
    <sensor type="camera" name="nova_robot_rgb_camera">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <camera name="rgb_camera">
        <!-- D435 RGB: 69.4° horizontal FOV = 1.2112 rad -->
        <horizontal_fov>1.2112</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>10.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin name="nova_robot_camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>image_raw:=color/image_raw</remapping>
          <remapping>camera_info:=color/camera_info</remapping>
        </ros>
        <camera_name>rgb_camera</camera_name>
        <frame_name>camera_rgb_optical_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ========== DEPTH CAMERA ========== -->
  <gazebo reference="camera_link">
    <sensor type="depth" name="nova_robot_depth_camera">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <camera name="depth_camera">
        <!-- D435 Depth: 87° horizontal FOV = 1.5184 rad -->
        <horizontal_fov>1.5184</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>  <!-- ← MUST be float for depth -->
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>

      <!-- ↓ Use libgazebo_ros_camera.so, NOT libgazebo_ros_depth_camera.so -->
      <plugin name="nova_robot_depth_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>image_raw:=depth/image_raw</remapping>
          <remapping>camera_info:=depth/camera_info</remapping>
          <remapping>points:=depth/points</remapping>
        </ros>
        <camera_name>depth_camera</camera_name>
        <frame_name>camera_depth_optical_frame</frame_name>
        <point_cloud_cutoff>0.1</point_cloud_cutoff>
        <point_cloud_cutoff_max>10.0</point_cloud_cutoff_max>
      </plugin>
    </sensor>
  </gazebo>  
<!-- ==================== GAZEBO FRICTION ==================== -->

  <!-- Drive wheels: high traction -->
  <gazebo reference="wheel_left_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
  </gazebo>

  <gazebo reference="wheel_right_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
  </gazebo>

  <!-- Casters: near-zero friction so they slide freely -->
  <gazebo reference="caster_front_link">
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="caster_back_link">
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>





</robot>